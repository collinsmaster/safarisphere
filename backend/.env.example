# ==============================================================================
# Safari Sphere Backend Environment Configurations (Example)
# Ensure all these variables are properly populated in your Koyeb Console!
# ==============================================================================

# Server Settings
PORT=8080
NODE_ENV=production
CORS_ORIGIN=*

# PostgreSQL Database Configuration
# You can use a unified connection string (Koyeb Database URL) or separate variables.
# Format: postgres://username:password@hostname:port/database_name?sslmode=require
DATABASE_URL=postgres://u_safari_user:password_placeholder@pg-instance.koyeb.app:5432/safari_db?sslmode=require

# In case your app configuration uses separate fields:
DB_HOST=pg-instance.koyeb.app
DB_PORT=5432
DB_USER=u_safari_user
DB_PASSWORD=password_placeholder
DB_NAME=safari_db
DB_SSL=true

# JWT Authentication Configuration
JWT_SECRET=your_super_secret_jwt_hmac_sha256_key_at_least_32_chars
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_key_for_rotation
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis Configuration (Optional, for caching and live session tracking fallback)
REDIS_URL=redis://default:redis_password_placeholder@redis-instance.koyeb.app:6379

# Gemini API Key (For SphereMate AI Assistant integration)
# Put your secure Google AI Studio API key here!
GEMINI_API_KEY=AIzaSy_your_gemini_api_key_goes_here

# Mock Mode Configuration (Optional, set to 'true' to run without a live Postgres DB)
USE_MOCK_DATABASE=false
